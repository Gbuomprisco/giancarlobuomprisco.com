{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "printWidth": 80,
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "sortImports": {
    "groups": ["external", ["parent", "sibling", "index"], "style"],
    "newlinesBetween": true,
    "order": "asc"
  },
  "sortTailwindcss": {
    "functions": ["tw", "clsx", "cn", "cva"]
  },
  "ignorePatterns": ["node_modules"]
}
