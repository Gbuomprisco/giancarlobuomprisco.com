---
import { GITHUB_URL, TWITTER_URL, LINKEDIN_URL, EMAIL } from '#consts.ts';
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-border pt-8 pb-12 text-sm text-muted">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <span>&copy; {year} Giancarlo Buomprisco</span>
    <div class="flex gap-4">
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground no-underline transition-colors">GitHub</a>
      <a href={TWITTER_URL} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground no-underline transition-colors">X</a>
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground no-underline transition-colors">LinkedIn</a>
      <a href={`mailto:${EMAIL}`} class="text-muted hover:text-foreground no-underline transition-colors">Email</a>
    </div>
  </div>
</footer>
