---
import BaseLayout from '#layouts/BaseLayout.astro';
import ArticleList from '#components/ArticleList.astro';
import { getListableArticles } from '#lib/articles.ts';
import { SITE_TITLE, SITE_DESCRIPTION } from '#consts.ts';

const articles = await getListableArticles();
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="mb-12">
    <p class="text-muted leading-relaxed">
      I'm a Software Developer and Founder.<br />
      I build <a href="https://makerkit.dev" target="_blank" rel="noopener noreferrer">MakerKit</a> and <a href="https://formtoro.com" target="_blank" rel="noopener noreferrer">Formtoro</a>.
    </p>
  </section>

  {articles.length > 0 && (
    <section>
      <ArticleList articles={articles} />
    </section>
  )}
</BaseLayout>
